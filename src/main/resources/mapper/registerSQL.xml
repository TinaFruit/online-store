<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.springproject.mapper.RegisterMapper">

    <insert id="add">
   insert into Users (user_name, password) values(#{username},#{password})
    </insert>


    <select id="checkDuplicatedRegister" resultType="Integer">
     select count(*) from Users where user_name = #{username}
    </select>

</mapper>