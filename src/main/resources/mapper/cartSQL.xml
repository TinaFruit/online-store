<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.springproject.mapper.CartMappe">


    <resultMap id="cartMapperCartJoinProductDTO" type="com.example.springproject.model.CartJoinProductDTO">
        <id column="id" property="id"/>
        <result column="product_id" property="productId"/>
        <result column="product_name" property="productName"/>
        <result column="image_url" property="imageUrl"/>
        <result column="price" property="price"/>
        <result column="quantity" property="quantity"/>
        <result column="selected" property="selected"/>
    </resultMap>


    <select id="searchCart" resultMap="cartMapperCartJoinProductDTO">
        select * from cart_items c join products p on c.product_id=p.id where c.id = #{id}
    </select>

    <select id="maps" resultType="map">
        select * from cart_items c join products p on c.product_id=p.id where c.user_id = #{userid}
    </select>


</mapper>

 