<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.springproject.mapper.UpdateUserInfoMapper">

    <update id="updateUserSql">
        update users
        <set>
            <if test="updatedUserName != null and updatedUserName !=''">
                user_Name = #{updatedUserName},
            </if>
            <if test="updatedPassword != null and updatedPassword !=''">
                password = #{updatedPassword},
            </if>
        </set>
        where user_Name = #{userName}
    </update>
</mapper>